PORT=3001
# SMTP — required for OTP email login
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Enterprise OpenClaw <your-email@gmail.com>"
DATABASE_URL="postgresql://openclaw:openclaw_dev@localhost:5432/enterprise_openclaw?schema=public"
REDIS_URL="redis://localhost:6379"
QDRANT_URL="http://localhost:6333"
JWT_SECRET="change-me-in-production"
OPENCLAW_GATEWAY_URL="ws://127.0.0.1:18789"
OPENCLAW_WORKSPACE_ROOT="C:/tmp/openclaw-workspaces"
# WeChat Work (企业微信) channel defaults (can also be set per-agent in AgentChannel.channelConfig)
WECOM_CORP_ID=""
WECOM_CORP_SECRET=""
WECOM_AGENT_ID=""
WECOM_TOKEN=""
WECOM_ENCODING_AES_KEY=""
